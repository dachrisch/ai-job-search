{
  "name": "job-search",
  "version": "0.2.6",
  "private": true,
  "workspaces": [
    "packages/api",
    "packages/frontend",
    "packages/shared"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces",
    "startup": "./scripts/dev-startup.sh",
    "stop": "./scripts/dev-stop.sh",
    "start:api": "cd packages/api && MONGODB_URI=mongodb://10.185.182.250:27017/job_search REDIS_URL=redis://10.185.182.250:6379 npm run dev",
    "start:frontend": "cd packages/frontend && npm run dev",
    "start:dev": "npm-run-all --parallel start:api start:frontend"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "mongodb-memory-server": "^11.1.0",
    "npm-run-all2": "^9.0.0",
    "redis-mock": "^0.56.3"
  }
}
